[include]
  path = ~/.gitconfig.local # add user.name and user.email here

[alias]
  browse = "!fd . --type f --hidden | fzf --preview 'bat --style=header,numbers --color=always {}'"

  last = log -1 HEAD --pretty=fuller
  ll = log --all --decorate --graph --oneline
  today = log --all --graph --oneline --since='midnight' --pretty=format:'%C(yellow)%h%Creset%C(auto)%d%Creset %s %C(cyan)<%an>%Creset %Cgreen(%cr)'

  commits = "!git log --decorate --oneline --color=always | fzf --ansi --preview 'git show --color=always {1} | delta --width=111' --preview-window=right:60%"
  deleted = ls-files --deleted
  modified = "!git ls-files --modified | fzf --preview 'git diff --color=always {} | delta --width=140' --preview-window=right:75%"
  staged = "!git diff --name-only --cached | fzf --preview 'git diff --cached --color=always {} | delta --width=140' --preview-window=right:75%"
  untracked = "!git ls-files --others --exclude-standard | fzf --preview 'bat --style=numbers --color=always {}' --preview-window=right:60%"
  restore-select = "!git ls-files --deleted | fzf --multi --preview 'git show HEAD:{} | bat' --preview-window=right:60% | xargs -r git restore"

  cd = switch
  mkdir = switch -c
  rmdir = branch -d

  uncommit = reset --soft HEAD^
  unstage = reset HEAD --

  discard = reset HEAD --hard
  discardhunk = checkout -p

[color]
  ui = auto

[color "branch"]
  current = green bold
  local = yellow dim
  remote = cyan

[color "status"]
  added = green
  changed = yellow
  untracked = red

[commit]
  template = ~/.gitmessages/default.txt

[core]
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  features = catppuccin-frappe side-by-side line-numbers decorations
  navigate = true  # use n and N to move between diff sections

[delta "catppuccin-frappe"]
	blame-palette = "#303446 #292c3c #232634 #414559 #51576d"
	commit-decoration-style = "#737994" bold box ul
	dark = true
	file-decoration-style = "#737994"
	file-style = "#c6d0f5"
	hunk-header-decoration-style = "#737994" box ul
	hunk-header-file-style = bold
	hunk-header-line-number-style = bold "#a5adce"
	hunk-header-style = file line-number syntax
	line-numbers-left-style = "#737994"
	line-numbers-minus-style = bold "#e78284"
	line-numbers-plus-style = bold "#a6d189"
	line-numbers-right-style = "#737994"
	line-numbers-zero-style = "#737994"
	# 35% red 65% base
	minus-emph-style = bold syntax "#704f5c"
	# 20% red 80% base
	minus-style = syntax "#544452"
	# 35% green 65% base
	plus-emph-style = bold syntax "#596b5e"
	# 20% green 80% base
	plus-style = syntax "#475453"
	map-styles = \
		bold purple => syntax "#66597e", \
		bold blue => syntax "#505d81", \
		bold cyan => syntax "#546b7a", \
		bold yellow => syntax "#6f6860"
	# Should match the name of the bat theme
	syntax-theme = Catppuccin Frappe

[merge]
    conflictStyle = zdiff3
